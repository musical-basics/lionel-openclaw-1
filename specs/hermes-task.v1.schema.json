{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/musical-basics/lionel-openclaw-1/specs/hermes-task.v1.schema.json",
  "title": "Hermes Task Create Request",
  "description": "Standalone JSON Schema for POST /v1/tasks in the Hermes Gateway API.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "command",
    "agent",
    "objective",
    "priority",
    "context",
    "assets",
    "constraints",
    "successCriteria",
    "approval",
    "callback"
  ],
  "properties": {
    "schemaVersion": {
      "const": "hermes.task.v1"
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flowId", "taskId", "requestedAt", "requester"],
      "properties": {
        "flowId": { "type": "string" },
        "taskId": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "requester": {
          "type": "object",
          "additionalProperties": false,
          "required": ["agent", "sessionKey", "user"],
          "properties": {
            "agent": { "type": "string" },
            "sessionKey": { "type": "string" },
            "user": { "type": "string" }
          }
        }
      }
    },
    "agent": {
      "type": "string",
      "enum": ["marketing", "development", "operations"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "deadline": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string" },
        "project": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "label", "value"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["url", "path", "file", "note", "repo", "doc"]
          },
          "label": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "successCriteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "kind"],
      "properties": {
        "required": { "type": "boolean" },
        "kind": { "type": ["string", "null"] }
      }
    },
    "callback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "url", "secret", "events"],
      "properties": {
        "mode": {
          "type": "string",
          "const": "webhook"
        },
        "url": { "type": "string", "format": "uri" },
        "secret": { "type": "string" },
        "events": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["waiting", "blocked", "completed", "failed", "cancelled"]
          }
        }
      }
    }
  },
  "examples": [
    {
      "schemaVersion": "hermes.task.v1",
      "command": {
        "flowId": "flow_01JRM7K8KQZ3W7QJ5P3S1E2ABC",
        "taskId": "task_01JRM7KAW3N3JQX9A1CDEF2345",
        "requestedAt": "2026-04-15T08:30:00Z",
        "requester": {
          "agent": "command",
          "sessionKey": "agent:main:telegram:direct:8155333249",
          "user": "Lionel"
        }
      },
      "agent": "operations",
      "objective": "Update masterclass migration tracker for 12 lessons and return a clean status summary.",
      "priority": "high",
      "deadline": "2026-04-16T02:00:00Z",
      "context": {
        "summary": "Masterclass launch is top priority. Hermes should only do migration tracking, not pricing or publishing.",
        "project": "ultimate-pianist-masterclass",
        "notes": [
          "Use existing naming conventions.",
          "Escalate immediately if lesson assets are missing or product structure looks inconsistent."
        ]
      },
      "assets": [
        {
          "type": "url",
          "label": "migration-sheet",
          "value": "https://example.com/masterclass-tracker"
        }
      ],
      "constraints": [
        "Do not publish anything.",
        "Do not change pricing or product structure."
      ],
      "successCriteria": [
        "Tracker updated for all assigned lessons.",
        "List blockers explicitly."
      ],
      "approval": {
        "required": false,
        "kind": null
      },
      "callback": {
        "mode": "webhook",
        "url": "http://100.88.10.4:19001/hermes/callback",
        "secret": "command_callback_secret",
        "events": ["waiting", "blocked", "completed", "failed", "cancelled"]
      }
    }
  ]
}
